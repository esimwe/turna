generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChatType {
  DIRECT
  GROUP
}

enum ChatMemberRole {
  OWNER
  ADMIN
  EDITOR
  MEMBER
}

enum ChatMemberAddPolicy {
  OWNER_ONLY
  ADMIN_ONLY
  EDITOR_ONLY
  EVERYONE
}

enum ChatPolicyScope {
  OWNER_ONLY
  ADMIN_ONLY
  EDITOR_ONLY
  EVERYONE
}

enum ChatJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MessageStatus {
  sent
  delivered
  read
}

enum ScheduledMessageStatus {
  PENDING
  PROCESSING
  SENT
  CANCELED
  FAILED
}

enum AttachmentKind {
  IMAGE
  VIDEO
  FILE
}

enum AttachmentTransferMode {
  STANDARD
  HD
  DOCUMENT
}

enum PushPlatform {
  IOS
  ANDROID
}

enum PushTokenKind {
  STANDARD
  VOIP
}

enum CallType {
  AUDIO
  VIDEO
}

enum CallStatus {
  RINGING
  ACCEPTED
  DECLINED
  MISSED
  ENDED
  CANCELLED
}

enum CallProvider {
  LIVEKIT
}

enum UserAccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum AdminRole {
  SUPER_ADMIN
  OPS_ADMIN
  SUPPORT_ADMIN
  MODERATOR
  ANALYST
}

enum OtpCodePurpose {
  LOGIN
  PHONE_CHANGE
}

enum OtpProvider {
  NETGSM_BULK
  NETGSM_OTP
  MOCK
}

enum SmsProvider {
  NETGSM_BULK
  NETGSM_OTP
  MOCK
}

enum ReportTargetType {
  USER
  MESSAGE
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  ACTIONED
  REJECTED
  RESOLVED
}

enum StatusType {
  TEXT
  IMAGE
  VIDEO
}

enum StatusPrivacyMode {
  MY_CONTACTS
  EXCLUDED_CONTACTS
  ONLY_SHARED_WITH
}

enum CommunityVisibility {
  PUBLIC
  REQUEST_ONLY
  INVITE_ONLY
}

enum CommunityMemberRole {
  OWNER
  ADMIN
  MODERATOR
  MENTOR
  MEMBER
}

enum CommunityChannelType {
  CHAT
  ANNOUNCEMENT
  QUESTION
  RESOURCE
  EVENT
}

enum CommunityTopicType {
  QUESTION
  RESOURCE
  EVENT
}

enum CommunityEventRsvpStatus {
  GOING
  MAYBE
  NOT_GOING
}

enum CommunityNotificationType {
  REPLY
  MENTION
  ANNOUNCEMENT
  DM_REQUEST
}

enum CommunityJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum CommunityInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum CommunityDmRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id                    String             @id @default(uuid())
  username              String?            @unique
  passwordHash          String?
  displayName           String
  phone                 String?            @unique
  email                 String?            @unique
  avatarUrl             String?
  about                 String?
  moodEmoji             String?
  city                  String?
  country               String?
  expertise             String?
  communityRole         String?
  interests             Json?
  socialLinks           Json?
  accountStatus         UserAccountStatus  @default(ACTIVE)
  accountStatusReason   String?
  otpBlocked            Boolean            @default(false)
  sendRestricted        Boolean            @default(false)
  callRestricted        Boolean            @default(false)
  onboardingCompletedAt DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  usernameChangeWindowStartedAt DateTime?
  usernameChangeCount   Int                @default(0)
  lastSeenAt            DateTime?
  messages              Message[]
  scheduledMessages     ScheduledMessage[]
  memberships           ChatMember[]
  devices               DeviceToken[]
  authSessions          AuthSession[]
  chatFolders           ChatFolder[]
  outgoingCalls         Call[]             @relation("OutgoingCalls")
  incomingCalls         Call[]             @relation("IncomingCalls")
  blockedUsers          UserBlock[]        @relation("UserBlocks")
  blockedByUsers        UserBlock[]        @relation("BlockedByUsers")
  syncedContacts        UserContact[]
  statusItems           StatusItem[]       @relation("StatusAuthor")
  statusViews           StatusView[]       @relation("StatusViewer")
  statusPreference      StatusPreference?
  privacyPreference     UserPrivacyPreference?
  submittedReports      ReportCase[]       @relation("SubmittedReports")
  reportsAgainst        ReportCase[]       @relation("ReportedUsers")
  createdChatInviteLinks ChatInviteLink[]  @relation("ChatInviteLinkCreator")
  chatJoinRequests      ChatJoinRequest[]  @relation("ChatJoinRequestRequester")
  reviewedChatJoinRequests ChatJoinRequest[] @relation("ChatJoinRequestReviewer")
  chatMutesReceived     ChatMute[]         @relation("ChatMutedUser")
  chatMutesApplied      ChatMute[]         @relation("ChatMuteActor")
  chatBansReceived      ChatBan[]          @relation("ChatBannedUser")
  chatBansApplied       ChatBan[]          @relation("ChatBanActor")
  mentionedInMessages   MessageMention[]   @relation("MessageMentionedUser")
  messageReactions      MessageReaction[]  @relation("MessageReactionUser")
  pinnedChatMessages    ChatPinnedMessage[] @relation("ChatPinnedMessageUser")
  reactionPackPreference UserReactionPreference?
  reactionPackUsageEvents ReactionPackUsageEvent[]
  expressionPackUsageEvents ExpressionPackUsageEvent[]
  communityMemberships  CommunityMembership[]
  communityMessages     CommunityMessage[]   @relation("CommunityMessageAuthor")
  communityTopics       CommunityTopic[]     @relation("CommunityTopicAuthor")
  communityTopicReplies CommunityTopicReply[] @relation("CommunityTopicReplyAuthor")
  communityNotifications CommunityNotification[]
  communityJoinRequests CommunityJoinRequest[] @relation("CommunityJoinRequester")
  reviewedCommunityJoinRequests CommunityJoinRequest[] @relation("CommunityJoinReviewer")
  communityInvitesReceived CommunityInvite[] @relation("CommunityInviteRecipient")
  communityInvitesSent   CommunityInvite[]   @relation("CommunityInviteCreator")
  communityBans          CommunityBan[]
  communityDmRequestsSent CommunityDmRequest[] @relation("CommunityDmRequester")
  communityDmRequestsReceived CommunityDmRequest[] @relation("CommunityDmRecipient")
  communityTopicEventPreferences CommunityTopicEventPreference[]
  communityMessageReactions CommunityMessageReaction[]
  communityReportsSubmitted CommunityReport[] @relation("CommunityReportReporter")
  communityReportsAgainst CommunityReport[] @relation("CommunityReportTarget")

  @@index([accountStatus])
}

enum UserPrivacyAudience {
  EVERYONE
  MY_CONTACTS
  EXCLUDED_CONTACTS
  NOBODY
  ONLY_SHARED_WITH
}

enum UserOnlineVisibility {
  EVERYONE
  SAME_AS_LAST_SEEN
}

model UserContact {
  id          String   @id @default(uuid())
  ownerId     String
  displayName String
  lookupKey   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, lookupKey])
  @@index([ownerId, displayName])
  @@index([ownerId, updatedAt])
}

model Chat {
  id                  String              @id @default(uuid())
  type                ChatType
  title               String?
  avatarUrl           String?
  description         String?
  createdByUserId     String?
  isPublic            Boolean             @default(false)
  joinApprovalRequired Boolean            @default(false)
  memberAddPolicy     ChatMemberAddPolicy @default(ADMIN_ONLY)
  whoCanSend          ChatPolicyScope     @default(EVERYONE)
  whoCanEditInfo      ChatPolicyScope     @default(EDITOR_ONLY)
  whoCanInvite        ChatPolicyScope     @default(ADMIN_ONLY)
  whoCanAddMembers    ChatPolicyScope     @default(ADMIN_ONLY)
  whoCanStartCalls    ChatPolicyScope     @default(EDITOR_ONLY)
  historyVisibleToNewMembers Boolean      @default(true)
  messageExpirationSeconds Int?
  usesDefaultMessageExpiration Boolean     @default(false)
  defaultMessageExpirationUserId String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @default(now()) @updatedAt
  members             ChatMember[]
  messages            Message[]
  scheduledMessages   ScheduledMessage[]
  inviteLinks         ChatInviteLink[]
  joinRequests        ChatJoinRequest[]
  mutes               ChatMute[]
  bans                ChatBan[]
  pinnedMessages      ChatPinnedMessage[]

  @@index([type, updatedAt(sort: Desc)])
  @@index([type, usesDefaultMessageExpiration, defaultMessageExpirationUserId])
  @@index([createdByUserId])
}

model ChatMember {
  chatId            String
  userId            String
  role              ChatMemberRole @default(MEMBER)
  canSend           Boolean        @default(true)
  addedByUserId     String?
  joinedVia         String?
  lastReadMessageId String?
  joinedAt          DateTime       @default(now())
  hiddenAt          DateTime?
  clearedAt         DateTime?
  archivedAt        DateTime?
  muted             Boolean        @default(false)
  favorited         Boolean        @default(false)
  locked            Boolean        @default(false)
  folderId          String?

  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder    ChatFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@id([chatId, userId])
  @@index([userId])
  @@index([chatId, role])
  @@index([userId, hiddenAt])
  @@index([userId, clearedAt])
  @@index([userId, archivedAt])
  @@index([userId, favorited])
  @@index([userId, locked])
  @@index([userId, folderId])
}

model ChatFolder {
  id        String       @id @default(uuid())
  userId    String
  name      String
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  members   ChatMember[]

  @@index([userId, sortOrder])
  @@unique([userId, name])
}

model ChatInviteLink {
  id              String   @id @default(uuid())
  chatId          String
  createdByUserId String
  token           String   @unique
  expiresAt       DateTime?
  revokedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  chat            Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  createdByUser   User     @relation("ChatInviteLinkCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt(sort: Desc)])
  @@index([token])
  @@index([createdByUserId, createdAt(sort: Desc)])
}

model ChatJoinRequest {
  id               String                @id @default(uuid())
  chatId           String
  userId           String
  status           ChatJoinRequestStatus @default(PENDING)
  reviewedByUserId String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  reviewedAt       DateTime?

  chat             Chat                  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user             User                  @relation("ChatJoinRequestRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewedByUser   User?                 @relation("ChatJoinRequestReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([chatId, status, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@unique([chatId, userId, status])
}

model ChatMute {
  id            String   @id @default(uuid())
  chatId        String
  userId        String
  mutedByUserId String
  reason        String?
  mutedUntil    DateTime?
  revokedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  chat          Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user          User     @relation("ChatMutedUser", fields: [userId], references: [id], onDelete: Cascade)
  mutedByUser   User     @relation("ChatMuteActor", fields: [mutedByUserId], references: [id], onDelete: Cascade)

  @@index([chatId, userId, revokedAt, mutedUntil])
  @@index([userId, createdAt(sort: Desc)])
}

model ChatBan {
  id            String   @id @default(uuid())
  chatId        String
  userId        String
  bannedByUserId String
  reason        String?
  revokedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  chat          Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user          User     @relation("ChatBannedUser", fields: [userId], references: [id], onDelete: Cascade)
  bannedByUser  User     @relation("ChatBanActor", fields: [bannedByUserId], references: [id], onDelete: Cascade)

  @@index([chatId, userId, revokedAt])
  @@index([userId, createdAt(sort: Desc)])
}

model UserBlock {
  blockerId     String
  blockedUserId String
  createdAt     DateTime @default(now())

  blocker       User     @relation("UserBlocks", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedUser   User     @relation("BlockedByUsers", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedUserId])
  @@index([blockedUserId])
}

model StatusItem {
  id              String      @id @default(uuid())
  authorId        String
  type            StatusType
  text            String?
  textLayout      String?     @db.Text
  backgroundColor String?
  textColor       String?
  objectKey       String?     @unique
  contentType     String?
  fileName        String?
  sizeBytes       Int?
  width           Int?
  height          Int?
  durationSeconds Int?
  createdAt       DateTime    @default(now())
  expiresAt       DateTime
  updatedAt       DateTime    @updatedAt

  author          User        @relation("StatusAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  views           StatusView[]

  @@index([authorId, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@index([authorId, expiresAt])
}

model StatusView {
  statusId      String
  viewerUserId  String
  viewedAt      DateTime   @default(now())

  status        StatusItem @relation(fields: [statusId], references: [id], onDelete: Cascade)
  viewer        User       @relation("StatusViewer", fields: [viewerUserId], references: [id], onDelete: Cascade)

  @@id([statusId, viewerUserId])
  @@index([viewerUserId, viewedAt(sort: Desc)])
}

model StatusPreference {
  userId         String            @id
  privacyMode    StatusPrivacyMode @default(MY_CONTACTS)
  targetUserIds  Json?
  mutedUserIds   Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPrivacyPreference {
  userId                     String               @id
  lastSeenMode               UserPrivacyAudience  @default(EVERYONE)
  lastSeenTargetUserIds      Json?
  onlineMode                 UserOnlineVisibility @default(EVERYONE)
  profilePhotoMode           UserPrivacyAudience  @default(EVERYONE)
  profilePhotoTargetUserIds  Json?
  aboutMode                  UserPrivacyAudience  @default(MY_CONTACTS)
  aboutTargetUserIds         Json?
  linksMode                  UserPrivacyAudience  @default(MY_CONTACTS)
  linksTargetUserIds         Json?
  groupsMode                 UserPrivacyAudience  @default(EVERYONE)
  groupsTargetUserIds        Json?
  defaultMessageExpirationSeconds Int?
  statusAllowReshare         Boolean              @default(false)
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt

  user                       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([updatedAt(sort: Desc)])
}

model UserReactionPreference {
  userId            String   @id
  installedPackIds  Json?
  favoriteEmojis    Json?
  recentEmojis      Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([updatedAt(sort: Desc)])
}

model ReactionPackUsageEvent {
  id        String   @id @default(uuid())
  userId    String
  packId    String
  emoji     String
  surface   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([packId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([surface, createdAt(sort: Desc)])
}

model ExpressionPackUsageEvent {
  id          String   @id @default(uuid())
  userId      String
  packId      String
  packVersion String
  itemId      String
  assetType   String
  surface     String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([packId, packVersion, createdAt(sort: Desc)])
  @@index([itemId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([surface, createdAt(sort: Desc)])
}

model Message {
  id            String              @id @default(uuid())
  chatId        String
  senderId      String
  text          String?
  systemType    String?
  systemPayload Json?
  status        MessageStatus      @default(sent)
  isViewOnce    Boolean            @default(false)
  editedAt      DateTime?
  editCount     Int                @default(0)
  editHistory   Json?
  createdAt     DateTime           @default(now())
  readAt        DateTime?
  expiresAt     DateTime?

  chat          Chat               @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender        User               @relation(fields: [senderId], references: [id], onDelete: Cascade)
  attachments   MessageAttachment[]
  reports       ReportCase[]
  mentions      MessageMention[]
  reactions     MessageReaction[]
  pins          ChatPinnedMessage[]

  @@index([chatId, createdAt(sort: Desc)])
  @@index([chatId, systemType, createdAt(sort: Desc)])
  @@index([chatId, expiresAt])
}

model ScheduledMessage {
  id               String                 @id @default(uuid())
  chatId           String
  senderId         String
  text             String
  silent           Boolean                @default(false)
  scheduledFor     DateTime
  status           ScheduledMessageStatus @default(PENDING)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  sentAt           DateTime?
  canceledAt       DateTime?
  lastError        String?
  deliveredMessageId String?

  chat             Chat                   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender           User                   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([chatId, senderId, status, scheduledFor(sort: Asc)])
}

model MessageMention {
  messageId       String
  mentionedUserId String
  createdAt       DateTime @default(now())

  message         Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  mentionedUser   User     @relation("MessageMentionedUser", fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@id([messageId, mentionedUserId])
  @@index([mentionedUserId, createdAt(sort: Desc)])
}

model MessageReaction {
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation("MessageReactionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId, emoji])
  @@index([messageId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model ChatPinnedMessage {
  chatId         String
  messageId      String
  pinnedByUserId String
  createdAt      DateTime @default(now())
  unpinnedAt     DateTime?

  chat           Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  message        Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedByUser   User     @relation("ChatPinnedMessageUser", fields: [pinnedByUserId], references: [id], onDelete: Cascade)

  @@id([chatId, messageId])
  @@index([chatId, unpinnedAt, createdAt(sort: Desc)])
  @@index([messageId])
  @@index([pinnedByUserId, createdAt(sort: Desc)])
}

model MessageAttachment {
  id              String         @id @default(uuid())
  messageId        String
  objectKey        String         @unique
  kind             AttachmentKind
  transferMode     AttachmentTransferMode @default(STANDARD)
  fileName         String?
  contentType      String
  sizeBytes        Int
  width            Int?
  height           Int?
  durationSeconds  Int?
  createdAt        DateTime       @default(now())

  message          Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt(sort: Asc)])
}

model DeviceToken {
  id          String       @id @default(uuid())
  userId       String
  token        String       @unique
  platform     PushPlatform
  tokenKind    PushTokenKind @default(STANDARD)
  deviceLabel  String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model Call {
  id                String        @id @default(uuid())
  callerId          String
  calleeId          String
  type              CallType
  status            CallStatus    @default(RINGING)
  provider          CallProvider  @default(LIVEKIT)
  providerSessionId String?
  roomName          String?
  acceptedAt        DateTime?
  endedAt           DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  caller            User          @relation("OutgoingCalls", fields: [callerId], references: [id], onDelete: Cascade)
  callee            User          @relation("IncomingCalls", fields: [calleeId], references: [id], onDelete: Cascade)
  events            CallEvent[]

  @@index([callerId, createdAt(sort: Desc)])
  @@index([calleeId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model CallEvent {
  id          String   @id @default(uuid())
  callId      String
  actorUserId String?
  type        String
  payload     Json?
  createdAt   DateTime @default(now())
  call        Call     @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId, createdAt(sort: Asc)])
}

model OtpCode {
  id           String         @id @default(uuid())
  phone        String
  codeHash     String
  nonce        String
  purpose      OtpCodePurpose @default(LOGIN)
  provider     OtpProvider    @default(MOCK)
  consumedAt   DateTime?
  attemptCount Int            @default(0)
  expiresAt    DateTime
  requestIp    String?
  lastSentAt   DateTime       @default(now())
  createdAt    DateTime       @default(now())

  @@index([phone, createdAt(sort: Desc)])
  @@index([phone, purpose, createdAt(sort: Desc)])
}

model AuthSession {
  id           String   @id @default(uuid())
  userId       String
  deviceId     String?
  platform     String?
  deviceModel  String?
  osVersion    String?
  appVersion   String?
  localeTag    String?
  regionCode   String?
  connectionType String?
  countryIso   String?
  ipCountryIso String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now())
  revokedAt    DateTime?
  revokeReason String?

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([revokedAt])
}

model AdminUser {
  id                     String          @id @default(uuid())
  username               String          @unique
  passwordHash           String
  displayName            String
  role                   AdminRole       @default(SUPPORT_ADMIN)
  isActive               Boolean         @default(true)
  lastLoginAt            DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  auditLogs              AdminAuditLog[] @relation("AdminAuditActor")
  updatedFeatureFlags    FeatureFlag[]   @relation("FeatureFlagUpdatedBy")
  updatedCountryPolicies CountryPolicy[] @relation("CountryPolicyUpdatedBy")
  resolvedReports        ReportCase[]    @relation("ResolvedReports")
}

model AdminAuditLog {
  id           String    @id @default(uuid())
  actorAdminId String
  action       String
  targetType   String
  targetId     String?
  reason       String?
  metadata     Json?
  createdAt    DateTime  @default(now())

  actorAdmin   AdminUser @relation("AdminAuditActor", fields: [actorAdminId], references: [id], onDelete: Cascade)

  @@index([actorAdminId, createdAt(sort: Desc)])
  @@index([targetType, targetId])
}

model FeatureFlag {
  key              String     @id
  enabled          Boolean    @default(false)
  description      String?
  metadata         Json?
  updatedAt        DateTime   @updatedAt
  updatedByAdminId String?

  updatedByAdmin   AdminUser? @relation("FeatureFlagUpdatedBy", fields: [updatedByAdminId], references: [id], onDelete: SetNull)
}

model CountryPolicy {
  countryIso           String      @id
  countryName          String
  dialCode             String?
  isServiceEnabled     Boolean     @default(true)
  isSignupEnabled      Boolean     @default(true)
  isLoginEnabled       Boolean     @default(true)
  isOtpEnabled         Boolean     @default(true)
  isPhoneChangeEnabled Boolean     @default(true)
  isMessagingEnabled   Boolean     @default(true)
  isCallingEnabled     Boolean     @default(true)
  isMediaUploadEnabled Boolean     @default(true)
  smsProvider          SmsProvider @default(NETGSM_BULK)
  otpCooldownSeconds   Int?
  otpTtlSeconds        Int?
  otpPhoneLimit10m     Int?
  otpPhoneLimit24h     Int?
  otpIpLimit10m        Int?
  otpIpLimit24h        Int?
  notes                String?
  updatedAt            DateTime    @updatedAt
  updatedByAdminId     String?

  updatedByAdmin       AdminUser?  @relation("CountryPolicyUpdatedBy", fields: [updatedByAdminId], references: [id], onDelete: SetNull)
}

model Community {
  id                String                @id @default(uuid())
  slug              String                @unique
  name              String
  tagline           String?
  description       String?
  emoji             String?
  coverGradientFrom String?
  coverGradientTo   String?
  welcomeTitle      String?
  welcomeDescription String?
  entryChecklist    Json?
  rules             Json?
  visibility        CommunityVisibility   @default(PUBLIC)
  isListed          Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  memberships       CommunityMembership[]
  joinRequests      CommunityJoinRequest[]
  invites           CommunityInvite[]
  bans              CommunityBan[]
  dmRequests        CommunityDmRequest[]
  channels          CommunityChannel[]
  topics            CommunityTopic[]
  reports           CommunityReport[]

  @@index([isListed, createdAt(sort: Desc)])
}

model CommunityMembership {
  communityId String
  userId      String
  role        CommunityMemberRole @default(MEMBER)
  communityRole String?
  restrictedChannelIds Json?
  joinedAt    DateTime            @default(now())
  mutedUntil  DateTime?
  muteReason  String?

  community   Community           @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([communityId, userId])
  @@index([userId, joinedAt(sort: Desc)])
  @@index([communityId, role])
}

model CommunityJoinRequest {
  id               String                     @id @default(uuid())
  communityId      String
  requesterUserId  String
  note             String?
  status           CommunityJoinRequestStatus @default(PENDING)
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  community        Community                  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  requester        User                       @relation("CommunityJoinRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  reviewedBy       User?                      @relation("CommunityJoinReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([communityId, status, createdAt(sort: Desc)])
  @@index([requesterUserId, createdAt(sort: Desc)])
  @@unique([communityId, requesterUserId, status])
}

model CommunityInvite {
  id            String                @id @default(uuid())
  communityId   String
  invitedUserId String
  createdByUserId String
  note          String?
  status        CommunityInviteStatus @default(PENDING)
  respondedAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  community     Community             @relation(fields: [communityId], references: [id], onDelete: Cascade)
  invitedUser   User                  @relation("CommunityInviteRecipient", fields: [invitedUserId], references: [id], onDelete: Cascade)
  createdBy     User                  @relation("CommunityInviteCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([communityId, status, createdAt(sort: Desc)])
  @@index([invitedUserId, status, createdAt(sort: Desc)])
  @@unique([communityId, invitedUserId, status])
}

model CommunityBan {
  id             String    @id @default(uuid())
  communityId    String
  userId         String
  reason         String?
  bannedByUserId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  community      Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([communityId, createdAt(sort: Desc)])
}

model CommunityDmRequest {
  id              String                   @id @default(uuid())
  communityId     String
  requesterUserId String
  targetUserId    String
  note            String?
  status          CommunityDmRequestStatus @default(PENDING)
  respondedAt     DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  community       Community                @relation(fields: [communityId], references: [id], onDelete: Cascade)
  requester       User                     @relation("CommunityDmRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  target          User                     @relation("CommunityDmRecipient", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([communityId, status, createdAt(sort: Desc)])
  @@index([requesterUserId, status, createdAt(sort: Desc)])
  @@index([targetUserId, status, createdAt(sort: Desc)])
  @@unique([communityId, requesterUserId, targetUserId, status])
}

model CommunityChannel {
  id          String               @id @default(uuid())
  communityId String
  slug        String
  name        String
  description String?
  type        CommunityChannelType @default(CHAT)
  sortOrder   Int                  @default(0)
  isDefault   Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  community   Community            @relation(fields: [communityId], references: [id], onDelete: Cascade)
  messages    CommunityMessage[]
  topics      CommunityTopic[]

  @@unique([communityId, slug])
  @@index([communityId, sortOrder])
  @@index([communityId, isDefault])
}

model CommunityMessage {
  id               String            @id @default(uuid())
  channelId        String
  authorUserId     String
  text             String?
  attachments      Json?
  isPinned         Boolean           @default(false)
  replyToMessageId String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  channel          CommunityChannel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author           User              @relation("CommunityMessageAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  replyToMessage   CommunityMessage? @relation("CommunityMessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies          CommunityMessage[] @relation("CommunityMessageReplies")
  reactions        CommunityMessageReaction[]
  reports          CommunityReport[]

  @@index([channelId, createdAt(sort: Desc)])
  @@index([channelId, isPinned, createdAt(sort: Desc)])
  @@index([authorUserId, createdAt(sort: Desc)])
  @@index([replyToMessageId])
}

model CommunityMessageReaction {
  id          String           @id @default(uuid())
  messageId   String
  userId      String
  emoji       String
  createdAt   DateTime         @default(now())

  message     CommunityMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model CommunityTopic {
  id               String                       @id @default(uuid())
  communityId      String
  channelId        String?
  type             CommunityTopicType
  title            String
  body             String?
  authorUserId     String
  tags             Json?
  resourceCategory String?
  eventLocation    String?
  isPinned         Boolean                      @default(false)
  isSolved         Boolean                      @default(false)
  eventStartsAt    DateTime?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  community        Community                    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  channel          CommunityChannel?            @relation(fields: [channelId], references: [id], onDelete: SetNull)
  author           User                         @relation("CommunityTopicAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  replies          CommunityTopicReply[]
  eventPreferences CommunityTopicEventPreference[]

  @@index([communityId, type, createdAt(sort: Desc)])
  @@index([channelId, createdAt(sort: Desc)])
  @@index([authorUserId, createdAt(sort: Desc)])
}

model CommunityTopicReply {
  id           String         @id @default(uuid())
  topicId      String
  authorUserId String
  body         String
  isAccepted   Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  topic        CommunityTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author       User           @relation("CommunityTopicReplyAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([topicId, createdAt(sort: Asc)])
  @@index([authorUserId, createdAt(sort: Desc)])
}

model CommunityTopicEventPreference {
  topicId          String
  userId           String
  status           CommunityEventRsvpStatus?
  reminderEnabled  Boolean                  @default(false)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  topic            CommunityTopic           @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([topicId, userId])
  @@index([userId, updatedAt(sort: Desc)])
  @@index([topicId, status])
}

model CommunityNotification {
  id          String                    @id @default(uuid())
  userId      String
  type        CommunityNotificationType
  communityId String?
  channelId   String?
  messageId   String?
  topicId     String?
  title       String
  body        String?
  metadata    Json?
  readAt      DateTime?
  createdAt   DateTime                  @default(now())

  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([communityId, createdAt(sort: Desc)])
  @@index([channelId, createdAt(sort: Desc)])
  @@index([messageId])
}

model CommunityReport {
  id             String          @id @default(uuid())
  communityId    String
  reporterUserId String
  reportedUserId String?
  messageId      String?
  reasonCode     String
  details        String?
  status         ReportStatus    @default(OPEN)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  community      Community       @relation(fields: [communityId], references: [id], onDelete: Cascade)
  reporterUser   User            @relation("CommunityReportReporter", fields: [reporterUserId], references: [id], onDelete: Cascade)
  reportedUser   User?           @relation("CommunityReportTarget", fields: [reportedUserId], references: [id], onDelete: SetNull)
  message        CommunityMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([communityId, createdAt(sort: Desc)])
  @@index([reporterUserId, createdAt(sort: Desc)])
  @@index([reportedUserId])
  @@index([messageId])
  @@index([status, createdAt(sort: Desc)])
}

model ReportCase {
  id               String           @id @default(uuid())
  reporterUserId   String
  targetType       ReportTargetType
  reportedUserId   String?
  messageId        String?
  chatId           String?
  reasonCode       String
  details          String?
  status           ReportStatus     @default(OPEN)
  resolutionNote   String?
  resolvedAt       DateTime?
  resolvedByAdminId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  reporterUser     User             @relation("SubmittedReports", fields: [reporterUserId], references: [id], onDelete: Cascade)
  reportedUser     User?            @relation("ReportedUsers", fields: [reportedUserId], references: [id], onDelete: SetNull)
  message          Message?         @relation(fields: [messageId], references: [id], onDelete: SetNull)
  resolvedByAdmin  AdminUser?       @relation("ResolvedReports", fields: [resolvedByAdminId], references: [id], onDelete: SetNull)

  @@index([reporterUserId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([targetType, createdAt(sort: Desc)])
  @@index([reportedUserId])
  @@index([messageId])
  @@index([chatId])
}
