generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChatType {
  DIRECT
  GROUP
}

enum MessageStatus {
  sent
  delivered
  read
}

enum AttachmentKind {
  IMAGE
  VIDEO
  FILE
}

enum PushPlatform {
  IOS
  ANDROID
}

enum PushTokenKind {
  STANDARD
  VOIP
}

enum CallType {
  AUDIO
  VIDEO
}

enum CallStatus {
  RINGING
  ACCEPTED
  DECLINED
  MISSED
  ENDED
  CANCELLED
}

enum CallProvider {
  LIVEKIT
}

model User {
  id           String        @id @default(uuid())
  username     String?       @unique
  passwordHash String?
  displayName  String
  phone        String?       @unique
  email        String?       @unique
  avatarUrl    String?
  about        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     Message[]
  memberships  ChatMember[]
  devices      DeviceToken[]
  outgoingCalls Call[]       @relation("OutgoingCalls")
  incomingCalls Call[]       @relation("IncomingCalls")
}

model Chat {
  id        String       @id
  type      ChatType
  createdAt DateTime     @default(now())
  members   ChatMember[]
  messages  Message[]
}

model ChatMember {
  chatId    String
  userId    String
  joinedAt  DateTime @default(now())

  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([chatId, userId])
  @@index([userId])
}

model Message {
  id          String              @id @default(uuid())
  chatId       String
  senderId     String
  text         String?
  status       MessageStatus      @default(sent)
  isViewOnce   Boolean            @default(false)
  createdAt    DateTime           @default(now())
  readAt       DateTime?

  chat         Chat               @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender       User               @relation(fields: [senderId], references: [id], onDelete: Cascade)
  attachments  MessageAttachment[]

  @@index([chatId, createdAt(sort: Desc)])
}

model MessageAttachment {
  id              String         @id @default(uuid())
  messageId        String
  objectKey        String         @unique
  kind             AttachmentKind
  fileName         String?
  contentType      String
  sizeBytes        Int
  width            Int?
  height           Int?
  durationSeconds  Int?
  createdAt        DateTime       @default(now())

  message          Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt(sort: Asc)])
}

model DeviceToken {
  id          String       @id @default(uuid())
  userId       String
  token        String       @unique
  platform     PushPlatform
  tokenKind    PushTokenKind @default(STANDARD)
  deviceLabel  String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model Call {
  id                String        @id @default(uuid())
  callerId          String
  calleeId          String
  type              CallType
  status            CallStatus    @default(RINGING)
  provider          CallProvider  @default(LIVEKIT)
  providerSessionId String?
  roomName          String?
  acceptedAt        DateTime?
  endedAt           DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  caller            User          @relation("OutgoingCalls", fields: [callerId], references: [id], onDelete: Cascade)
  callee            User          @relation("IncomingCalls", fields: [calleeId], references: [id], onDelete: Cascade)
  events            CallEvent[]

  @@index([callerId, createdAt(sort: Desc)])
  @@index([calleeId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model CallEvent {
  id          String   @id @default(uuid())
  callId      String
  actorUserId String?
  type        String
  payload     Json?
  createdAt   DateTime @default(now())
  call        Call     @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId, createdAt(sort: Asc)])
}

model OtpCode {
  id        String   @id @default(uuid())
  target    String
  code      String
  consumed  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([target, createdAt(sort: Desc)])
}
